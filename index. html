        <div style={{ fontWeight:800, fontSize:15, marginBottom:12 }}>🎓 Course Settings</div>
        {[["courseName","Course Name","📚"],["teacher","Teacher Name","👨‍🏫"]].map(([k,ph,ic])=>(
          <input key={k} value={form[k]} onChange={e=>setForm(p=>({...p,[k]:e.target.value}))}
            placeholder={`${ic} ${ph}`}
            style={{ width:"100%", padding:"11px 13px", borderRadius:10, border:`1px solid ${c.border}`, background:c.card2, color:c.text, fontSize:13, marginBottom:10, boxSizing:"border-box" }} />
        ))}
        <div style={{ marginBottom:10 }}>
          <div style={{ fontSize:12, color:c.sub, marginBottom:5 }}>💰 Default Fee Amount (Rs.)</div>
          <input type="number" value={form.feeTotal} onChange={e=>setForm(p=>({...p,feeTotal:Number(e.target.value)}))}
            style={{ width:"100%", padding:"11px 13px", borderRadius:10, border:`1px solid ${c.border}`, background:c.card2, color:c.text, fontSize:13, boxSizing:"border-box" }} />
        </div>
        <button onClick={()=>onSave(form)}
          style={{ width:"100%", padding:12, borderRadius:10, background:"linear-gradient(135deg,#1d4ed8,#0284c7)", color:"#fff", border:"none", fontWeight:700, cursor:"pointer", fontSize:14 }}>
          💾 Save Settings
        </button>
      </div>

      {/* App info */}
      <div style={{ background:c.card, borderRadius:14, padding:14, border:`1px solid ${c.border}`, textAlign:"center" }}>
        <div style={{ fontSize:28, marginBottom:6 }}>🎓</div>
        <div style={{ fontWeight:800, fontSize:16 }}>VacationPro</div>
        <div style={{ fontSize:11, color:c.sub, marginTop:4 }}>30-Day Vacation Course Manager</div>
        <div style={{ fontSize:10, color:c.sub, marginTop:4 }}>Firebase Live Sync • WhatsApp Reports • Fee Tracking</div>
      </div>
    </div>
  );
}
